<div class="layout layout--top layout--col layout--stretch gap--large lg:gap--xlarge">
  {% if events.size > 0 %}
  <div class="">
    <div class="text--center">
      <div class="my--3 lg:my--6"><span class="title title--base lg:title--large" data-clamp="3">{{ events.first.short_title }}</span></div>
      <div><span class="label">{{ events.first.datetime_local | date: '%-I:%M %p %A, %B %-d, %Y' }}</span></div>
      <div><span class="description description--base lg:description--large">{{ events.first.venue.name }}</span></div>
      <div><span class="description description--base lg:description--large">{{ events.first.venue.display_location }}</span></div>
    </div>
  </div>
  <div class="h--72 lg:h--[550px]">
    {% if events.size > 1 %}
    <div>
      <span class="label label--small lg:label--base label--underline">Upcoming Dates</span>
    </div>
    <table class="table table--condensed" data-table-limit="true" data-table-max-height="auto">
    {% for event in events offset: 1 %}
      <tr>
        <td class="py--2 lg:py--3">
          <div><span class="title title--small lg:title--base" data--clamp="2">{{ event.short_title }}</span></div>
          <div class="flex flex--row">
            <div class="stretch"><span class="label label--small lg:label--base">{{ event.datetime_local | date: '%-I:%M %p %a, %B %-d, %Y' }}</span></div>
            <div><span class="label label--small lg:label--base">{{ event.venue.display_location }}</span></div>
          </div>
        </td>
      </tr>
    {% endfor %}
    </table>
    {% endif %}
  </div>

  {% else %}
    <div class="text--center py--10">
      <div><span class="title title--large clamp--none">No Scheduled Events</span></div>
      <div><span class="description">Query: {{ trmnl.plugin_settings.custom_fields_values.seatgeek_query }}</span></div>
    </div>
  {% endif %}
</div>

<div class="title_bar">
  <img class="image image-stroke" src="data:image/svg+xml;base64,{{ seatgeek_logo | base64_encode }}" />
  <span class="title">{{ trmnl.plugin_settings.custom_fields_values.seatgeek_query }}</span>
</div>
